# InsightGraph Environment Configuration

# 数据库相关配置
POSTGRES_USER=insight_admin
POSTGRES_PASSWORD=<YOUR_POSTGRES_PASSWORD>
POSTGRES_DB=insight_graph_db

# Redis 配置
REDIS_PASSWORD=<YOUR_REDIS_PASSWORD>

# n8n 配置
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=<YOUR_N8N_PASSWORD>
WEBHOOK_URL=http://localhost:5678/

# FastAPI 后端配置
API_PORT=8000

# Dify 环境变量（后续用到时填入 Dify 提供的 API Key）
DIFY_API_KEY=<YOUR_DIFY_DATASET_API_KEY>
DIFY_API_URL=http://insightgraph-api-1:5001/v1
# 【新增配置】填入你在第 4 步中获取的“聊天助手”应用 API 密钥：
DIFY_READER_API_KEY=<YOUR_DIFY_READER_APP_KEY>
DIFY_DEEP_READER_API_KEY=<YOUR_DIFY_DEEP_READER_APP_KEY>

# (可选) 知识库分类配置。
# Dify 中所有的知识库共享 DIFY_API_KEY，但你可以为不同分类配置不同的 ID 以路由到特定库中：
DIFY_DATASET_SKIM_ID=<YOUR_DATASET_UUID>
DIFY_DATASET_ORIGINAL_ID=<YOUR_DATASET_UUID>
DIFY_DATASET_CAPSULE_ID=<YOUR_DATASET_UUID>
DIFY_DATASET_DEEP_ID=<YOUR_DATASET_UUID>
DIFY_OCR_WORKFLOW_API_KEY=<YOUR_DIFY_OCR_WORKFLOW_KEY>
DIFY_GLOBAL_CHAT_API_KEY=<YOUR_DIFY_GLOBAL_CHAT_KEY>

# 飞书应用凭证（用于机器人交互）
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_ENCRYPT_KEY=your_feishu_encrypt_key
FEISHU_VERIFICATION_TOKEN=your_feishu_verification_token

