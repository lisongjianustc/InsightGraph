{
  "name": "insight-graph-desktop",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "electron:serve": "cross-env NODE_ENV=development concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.insightgraph.desktop",
    "productName": "InsightGraph",
    "directories": {
      "output": "dist_electron"
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "target": [
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  },
  "dependencies": {
    "@bytemd/plugin-breaks": "^1.22.0",
    "@bytemd/plugin-gfm": "^1.22.0",
    "@bytemd/plugin-highlight": "^1.22.0",
    "@bytemd/plugin-math": "^1.22.0",
    "@bytemd/vue-next": "^1.22.0",
    "@element-plus/icons-vue": "^2.3.1",
    "@vue-office/docx": "^1.6.3",
    "@vue-office/excel": "^1.7.14",
    "@vue-office/pdf": "^2.0.10",
    "@vue-office/pptx": "^1.0.1",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.6.7",
    "bytemd": "^1.22.0",
    "dompurify": "^3.3.3",
    "echarts": "^6.0.0",
    "element-plus": "^2.5.6",
    "highlight.js": "^11.11.1",
    "juejin-markdown-themes": "^1.34.0",
    "marked": "^17.0.5",
    "vue": "^3.4.19",
    "vue-demi": "^0.14.10",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/echarts": "^4.9.22",
    "@types/marked": "^5.0.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "vue-tsc": "^3.2.6",
    "wait-on": "^9.0.4"
  }
}
